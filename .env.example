# CloudPilot Local Environment Template
# Copy this file to '.env' to customize your local execution settings.

# Local Deno Gateway connection settings (defaults internally to port 54321)
SUPABASE_URL="http://localhost:54321"
SUPABASE_PUBLISHABLE_KEY="mock-anon-key"
VITE_SUPABASE_URL="http://localhost:54321"
VITE_SUPABASE_PUBLISHABLE_KEY="mock-anon-key"

# The local Ollama model to invoke (defaults to "qwen2.5-coder")
OLLAMA_MODEL="qwen2.5-coder"
